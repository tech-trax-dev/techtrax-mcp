# Never copy these into the build context / image
node_modules
dist
coverage
.git
.github
.idea
.vscode
*.log
logs

# Env files — secrets are injected at runtime, never baked into the image
.env
.env.*
!.env.example
!.env.production.example

# Dev / test / docs that don't belong in a runtime image
test
**/*.spec.ts
.prettierrc
eslint.config.mjs
README.md
DEPLOYMENT.md
Dockerfile
.dockerignore
docker-compose.yml
