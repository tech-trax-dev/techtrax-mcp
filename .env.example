# ─────────────────────────────────────────────────────────────────────────────
# Local development example. Copy to `.env` and adjust.
#   cp .env.example .env
# For production values see .env.production.example.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
HOST=0.0.0.0
PORT=3100

# Outbound: MCP -> Express (TechTrax backend)
BACKEND_BASE_URL=http://localhost:5000
BACKEND_API_KEY=replace-with-shared-internal-secret
BACKEND_TIMEOUT_MS=15000

# MCP server identity (advertised to clients)
MCP_SERVER_NAME=techtrax-mcp
MCP_SERVER_VERSION=1.0.0

# Inbound: AI client -> MCP. Optional in dev (empty = auth disabled).
# REQUIRED in production — the server refuses to boot without it.
MCP_CLIENT_API_KEY=

# Browser CORS allowlist (comma-separated). Empty = CORS disabled.
CORS_ALLOWED_ORIGINS=

# Set true when running behind a reverse proxy / load balancer / ingress.
TRUST_PROXY=false

# fatal | error | warn | info | debug | trace
LOG_LEVEL=debug
