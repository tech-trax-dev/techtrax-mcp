NODE_ENV=development
PORT=3100

# Outbound: MCP -> Express (TechTrax backend)
BACKEND_BASE_URL=http://localhost:5000
BACKEND_API_KEY=replace-with-shared-internal-secret
BACKEND_TIMEOUT_MS=15000

# MCP server identity (advertised to clients)
MCP_SERVER_NAME=techtrax-mcp
MCP_SERVER_VERSION=1.0.0

# Inbound: AI client -> MCP (optional in Phase 1; leave empty to disable client auth)
MCP_CLIENT_API_KEY=

# fatal | error | warn | info | debug | trace
LOG_LEVEL=info
