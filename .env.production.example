# ─────────────────────────────────────────────────────────────────────────────
# Production env template for the DevOps team.
# Copy to `.env.production` (gitignored) and fill in real values, OR map each
# key into your secrets manager (k8s Secret, SSM, Vault, etc.).
# Do NOT commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
HOST=0.0.0.0
PORT=3100

# Outbound: MCP -> Express (TechTrax backend). Use the internal service URL.
BACKEND_BASE_URL=https://api.internal.tech-trax.com
BACKEND_API_KEY=__SET_ME__shared-internal-secret
BACKEND_TIMEOUT_MS=15000

# MCP server identity (advertised to clients)
MCP_SERVER_NAME=techtrax-mcp
MCP_SERVER_VERSION=1.0.0

# Inbound auth — REQUIRED in production. Generate a strong random value, e.g.
#   openssl rand -hex 32
# Clients must send it as the `x-api-key` request header.
MCP_CLIENT_API_KEY=__SET_ME__strong-random-key

# Browser CORS allowlist (comma-separated). Leave empty for server-to-server.
CORS_ALLOWED_ORIGINS=

# Running behind an ALB / nginx / k8s ingress -> keep true.
TRUST_PROXY=true

# fatal | error | warn | info | debug | trace  (info recommended in prod)
LOG_LEVEL=info
